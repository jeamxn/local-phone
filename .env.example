# ===== Vertex AI Service Account (server-side only) =====
# These are consumed by apps/signal to authenticate the Gemini Live translation session.
# NEVER expose these to the browser.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=
VERTEX_CLIENT_EMAIL=
VERTEX_CLIENT_ID=
VERTEX_CLIENT_X509_CERT_URL=
VERTEX_PRIVATE_KEY_ID=
VERTEX_PRIVATE_KEY=
VERTEX_DNS_MAPPING=

# If your PaaS (Dokploy) mangles the multi-line PEM in VERTEX_PRIVATE_KEY,
# base64-encode the PEM and set this instead (takes precedence when present):
#   base64 -w0 <<< "$VERTEX_PRIVATE_KEY"
VERTEX_PRIVATE_KEY_B64=

# Gemini model used for realtime translation
GEMINI_TRANSLATE_MODEL=gemini-3.5-live-translate-preview

# ===== Signal server =====
SIGNAL_PORT=8080

# ===== Web =====
# Public URL of the signal server's websocket, as reached from the BROWSER.
# Local dev: ws://localhost:8080 . Production behind proxy: wss://signal.example.com
NEXT_PUBLIC_SIGNAL_URL=ws://localhost:8080

# Optional comma-separated extra ICE/STUN/TURN servers for the browser.
# Format: stun:host:port  OR  turn:host:port|user|credential
# Defaults to Google public STUN if empty.
NEXT_PUBLIC_ICE_SERVERS=
